    { "configuration": "ssn_no_header",     "plaintext": "abc",     "force_method": "protect_only", "expect_error": true, "error_must_contain": "encryptable",      "note": "[Zero encryptable characters] — 'abc' is not in 'digits' alphabet" },

    { "configuration": "ssn_no_header",     "plaintext": "123",     "force_method": "protect_only", "expect_error": true, "error_must_contain": "short",            "note": "[NIST FF1 minlen] — 3 chars in digits radix 10: 10^3=1000 < 1,000,000 (java enforces, others lax — known divergence)" },
    { "configuration": "ssn_no_header",     "plaintext": "12345",   "force_method": "protect_only", "expect_error": true, "error_must_contain": "short",            "note": "[NIST FF1 minlen] — 5 chars digits: 100,000 < 1,000,000" },
    { "configuration": "alpha_short",       "plaintext": "abc",     "force_method": "protect_only", "expect_error": true, "error_must_contain": "short",            "note": "[NIST FF1 minlen] — 3 chars alphanumeric radix 62: 238,328 < 1,000,000" },
    { "configuration": "ff3_digits_no",     "plaintext": "12345",   "force_method": "protect_only", "expect_error": true, "error_must_contain": "short",            "note": "[NIST FF3 minlen] — 5 chars digits same threshold" },
    { "configuration": "ff3_digits_no",     "plaintext": "1",       "force_method": "protect_only", "expect_error": true,                                          "note": "[NIST FF3 minlen + min 2] — single char" },

