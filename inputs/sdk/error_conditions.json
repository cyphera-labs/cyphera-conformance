    { "configuration": "ssn",               "plaintext": "123456789", "force_method": "access_by_header_unknown_prefix", "input_override": "",            "expect_error": true, "error_must_contain": "no matching header", "note": "[No matching header] — access_by_header on empty string" },
    { "configuration": "ssn",               "plaintext": "123456789", "force_method": "access_by_header_unknown_prefix", "input_override": "T01",         "expect_error": true,                                          "note": "[Edge] — input matches header prefix exactly but has no ciphertext after — should error somehow (no encryptable / too short)" },

