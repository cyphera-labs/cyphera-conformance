{
  "note": "API contract tests — explicitly exercise every canonical method exposed by every SDK. Failures here mean the SDK either doesn't expose the method, or behaves differently from the spec. Catches API surface divergence that crypto-roundtrip tests miss.",
  "config": {
    "configurations": {
      "ssn": {
        "engine": "ff1",
        "key_ref": "test-key",
        "header": "T01"
      },
      "ssn_no_header": {
        "engine": "ff1",
        "alphabet": "digits",
        "header_enabled": false,
        "key_ref": "test-key"
      },
      "cc": {
        "engine": "ff1",
        "key_ref": "test-key",
        "header": "T02"
      },
      "long_header": {
        "engine": "ff1",
        "alphabet": "alphanumeric",
        "key_ref": "test-key",
        "header": "ABCDE",
        "header_length": 5
      },
      "ssn_mask": {
        "engine": "mask",
        "pattern": "last4",
        "header_enabled": false
      },
      "ssn_hash": {
        "engine": "hash",
        "algorithm": "sha256",
        "key_ref": "test-key",
        "header_enabled": false
      }
    },
    "keys": {
      "test-key": {
        "material": "2B7E151628AED2A6ABF7158809CF4F3C"
      }
    }
  },
  "cases": [
    {
      "configuration": "ssn",
      "plaintext": "123456789",
      "force_method": "access_by_header",
      "note": "access_by_header on header_enabled=true config — canonical happy path"
    },
    {
      "configuration": "cc",
      "plaintext": "4111111111111111",
      "force_method": "access_by_header",
      "note": "access_by_header on second header_enabled=true config — different header prefix"
    },
    {
      "configuration": "long_header",
      "plaintext": "abcdefghij",
      "force_method": "access_by_header",
      "note": "access_by_header with a 5-char header — header_length non-default"
    },
    {
      "configuration": "ssn_no_header",
      "plaintext": "123456789",
      "force_method": "access",
      "note": "access(value, name) on header_enabled=false config — canonical 2-arg happy path"
    },
    {
      "configuration": "ssn",
      "plaintext": "123456789",
      "force_method": "access",
      "expect_error": true,
      "error_must_contain": "header_enabled=true",
      "note": "access(value, name) on header_enabled=true MUST error per Option C"
    },
    {
      "configuration": "ssn",
      "plaintext": "123456789",
      "force_method": "access_by_header_unknown_prefix",
      "expect_error": true,
      "error_must_contain": "no matching header",
      "input_override": "ZZZ123456789",
      "note": "access_by_header on a value that doesn't start with any known header MUST error"
    },
    {
      "configuration": "ssn_mask",
      "plaintext": "123-45-6789",
      "force_method": "protect_only",
      "expected": "*******6789",
      "note": "mask engine — verify protect output (mask is one-way)"
    },
    {
      "configuration": "ssn_hash",
      "plaintext": "123-45-6789",
      "force_method": "protect_only_deterministic",
      "note": "hash engine — verify protect is deterministic and one-way"
    },
    {
      "configuration": "nonexistent",
      "plaintext": "anything",
      "force_method": "protect_only",
      "expect_error": true,
      "error_must_contain": "configuration",
      "note": "protect with unknown configuration name MUST error"
    },
    {
      "configuration": "ssn_no_header",
      "plaintext": "123456789",
      "force_method": "access_by_header",
      "expect_error": true,
      "error_must_contain": "no matching header",
      "note": "access_by_header on output of a header_enabled=false config MUST error (no header to match)"
    }
  ]
}
