      "ssn_hash_sha512": {
        "engine": "hash", "algorithm": "sha512", "key_ref": "test-key", "header_enabled": false
      },
      "ssn_hash_plain_sha256": {
        "engine": "hash", "algorithm": "sha256", "header_enabled": false
      }
    },
    "keys": {
      "test-key": { "material": "2B7E151628AED2A6ABF7158809CF4F3C" }
    }
