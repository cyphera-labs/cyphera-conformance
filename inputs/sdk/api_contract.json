      "ssn_mask_last4": {
        "engine": "mask", "pattern": "last4", "header_enabled": false
      },
      "ssn_mask_first1": {
        "engine": "mask", "pattern": "first1", "header_enabled": false
      },
      "ssn_mask_full": {
        "engine": "mask", "pattern": "full", "header_enabled": false
      },
      "ssn_hash_sha256": {
        "engine": "hash", "algorithm": "sha256", "key_ref": "test-key", "header_enabled": false
